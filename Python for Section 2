import numpy as np
import matplotlib.pyplot as plt
import zipfile
import os
from google.colab import files

def generate_computational_coalition_figure():
    """Simulates the matrix-based characteristic value function under hardware limits."""
    
    # 1. Generate a discrete 1D physical signal vector
    N = 256
    t = np.linspace(0, 1, N, endpoint=False)
    
    # Base signal pushing the hardware limits (8-bit: 0 to 255)
    x_true = 120 + 85 * np.sin(2 * np.pi * 3 * t) + \
             45 * np.sin(2 * np.pi * 12 * t) + \
             30 * np.sin(2 * np.pi * 40 * t)
                  
    # 2. DFT Matrix Operation (X = W_N x)
    X = np.fft.fft(x_true) / np.sqrt(N) # Unitary normalization
    
    # Sort players (frequencies) by their magnitude/worth
    energy_order = np.argsort(np.abs(X))[::-1]
    
    # 3. Game-Theoretic Matrix Simulation
    latent_energy = []
    physical_energy = []
    
    # Empty spectral coalition vector
    X_S = np.zeros(N, dtype=complex)
    
    for i in range(1, N + 1):
        # Player joins the coalition
        new_player_idx = energy_order[i-1]
        X_S[new_player_idx] = X[new_player_idx]
        
        # Matrix reconstruction (Inverse DFT)
        x_S = np.real(np.fft.ifft(X_S) * np.sqrt(N))
        
        # Calculate Latent Worth (x_S^H x_S)
        latent_v = np.sum(x_S**2)
        latent_energy.append(latent_v)
        
        # Calculate Physical Worth (Hardware clipping)
        clipped_x_S = np.clip(x_S, 0, 255)
        physical_v = np.sum(clipped_x_S**2)
        physical_energy.append(physical_v)
        
    # 4. Plotting the Results
    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 8), dpi=300, gridspec_kw={'height_ratios': [1, 1.5]})
    
    # Panel 1: Spatial Signal
    ax1.plot(x_true, color='black', linewidth=2, label='Grand Coalition (True Signal $x$)')
    ax1.axhline(255, color='red', linestyle='--', alpha=0.5, label='Hardware Ceiling (255)')
    ax1.axhline(0, color='red', linestyle='--', alpha=0.5, label='Hardware Floor (0)')
    ax1.fill_between(range(N), 255, max(x_true)+20, color='red', alpha=0.1)
    ax1.fill_between(range(N), min(x_true)-20, 0, color='red', alpha=0.1)
    ax1.set_ylim(-20, 280)
    ax1.set_xlim(0, N)
    ax1.set_title("Computational Matrix Reconstruction vs. Physical Hardware Boundaries", fontweight='bold')
    ax1.set_ylabel("Pixel Intensity")
    ax1.legend(loc='upper right')
    ax1.grid(True, alpha=0.3)
    
    # Panel 2: The Characteristic Value Function v(S)
    coalition_sizes = np.arange(1, N + 1)
    norm_factor = latent_energy[-1]
    
    ax2.plot(coalition_sizes, np.array(latent_energy) / norm_factor, color='blue', linewidth=3, 
             label=r'Latent Energy $v(S)$ (Theorem II.1: Strict Additivity)')
    ax2.plot(coalition_sizes, np.array(physical_energy) / norm_factor, color='red', linewidth=3, linestyle='--',
             label=r'Physical Energy $\tilde{v}(S)$ (Sub-Additive Hardware Penalty)')
    
    ax2.fill_between(coalition_sizes, np.array(physical_energy)/norm_factor, np.array(latent_energy)/norm_factor, 
                     color='gray', alpha=0.2, label='The Quantization Tax')
    
    ax2.set_title("Characteristic Value Function: Matrix Energy Accumulation", fontweight='bold')
    ax2.set_xlabel("Size of Frequency Coalition $|S|$ (Number of Matrix Columns)")
    ax2.set_ylabel("Normalized Coalition Worth (Spatial Energy)")
    ax2.set_xlim(1, 40)
    ax2.set_ylim(0, 1.1)
    ax2.legend(loc='lower right', fontsize=11)
    ax2.grid(True, alpha=0.3)
    
    plt.tight_layout()
    
    filename = 'fig_coalition_hardware.png'
    plt.savefig(filename, bbox_inches='tight')
    plt.close()
    return filename

if __name__ == "__main__":
    fig_file = generate_computational_coalition_figure()
    zip_name = 'paper6_sec2_matrix_figures.zip'
    with zipfile.ZipFile(zip_name, 'w') as archive:
        archive.write(fig_file)
    files.download(zip_name)
